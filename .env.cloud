# Copy to /etc/alphard/.env.cloud on the VM, or let scripts/gcp/deploy_alphard_vm.sh generate it.
# Keep this file out of the Docker image. The container receives it via docker --env-file.

APP_NAME=alphard
APP_ENV=cloud
DRY_RUN=true
ALPHARD_DIAGNOSTICS_ONLY=true
LOG_LEVEL=INFO

# Scheduler cadence. The host systemd timer is authoritative; this stays here for app logging/compatibility.
RUN_INTERVAL_MINUTES=15
CANDLE_CLOSE_DELAY_SECONDS=30

# MT5 proxy on another VM. Prefer the proxy VM's INTERNAL IP when both VMs are in the same VPC.
MT5_BASE_URL=http://10.0.0.10:8000
MT5_API_KEY=replace-me
MT5_TIMEOUT_SECONDS=30
TRADING_ENABLED=false

# Instruments and data. These paths are inside the container and are backed by /var/lib/alphard on the VM.
SYMBOLS=EURUSD,USDJPY
MT5_TIMEFRAME=M15
CANDLE_WARMUP_BARS=220
CHART_WINDOW_BARS=96
SQLITE_PATH=data/alphard.sqlite3
DATA_DIR=data
IMAGE_CACHE_DIR=img_cache

# LiteLLM / Gemini via Vertex AI. On GCE, leave GOOGLE_APPLICATION_CREDENTIALS empty to use the VM service account ADC.
MODEL_NAME=gemini-2.5-pro
MODEL_ID=vertex_ai/gemini-2.5-pro
VERTEX_LOCATION=global
VERTEX_PROJECT=alphard3
GOOGLE_CLOUD_PROJECT=alphard3
# Leave unset on GCE so Google client libraries use the VM service account via ADC.
GOOGLE_APPLICATION_CREDENTIALS=
LITELLM_TIMEOUT_SECONDS=120
LITELLM_DEBUG=false
LITELLM_LOG=ERROR
LITELLM_LOG_PROMPT=false
LITELLM_LOG_RESPONSE=false
LITELLM_RESPONSE_PREVIEW_CHARS=600
LITELLM_DROP_PARAMS=true
LITELLM_SUPPRESS_PYDANTIC_WARNINGS=true

# Use GCS in cloud so chart refs are durable and available to Vertex/LiteLLM.
IMAGE_PROVIDER=gcs
GCS_BUCKET_NAME=charts-alphard3
GCS_PUBLIC_READ=false

# Strategy and execution.
STRATEGY_NAME=levels_strategy
EXECUTION_MODE=pending_limit
BASE_VOLUME=0.01
MAX_VOLUME=0.05
MIN_CONFIDENCE=0.55
MAX_ALLOCATION=0.50
MAX_ACTIVE_POSITIONS=1
ENTRY_PULLBACK_POINTS=30
MIN_STOP_DISTANCE_POINTS=20
CANCEL_STALE_PENDING_ORDERS=true
MT5_MAGIC=424242
MT5_TYPE_FILLING=AUTO
MT5_DEVIATION=30
