APP_NAME=alphard
APP_ENV=cloud
DRY_RUN=true
LOG_LEVEL=INFO
RUN_INTERVAL_MINUTES=15
CANDLE_CLOSE_DELAY_SECONDS=30

# On the VM, point this at the MT5 proxy host/port.
MT5_BASE_URL=http://127.0.0.1:8000
MT5_API_KEY=CHANGE_ME
TRADING_ENABLED=false

SYMBOLS=EURUSD
MT5_TIMEFRAME=M15
SQLITE_PATH=/opt/alphard/state/alphard.sqlite3
DATA_DIR=/opt/alphard/state/data
IMAGE_CACHE_DIR=/opt/alphard/state/img_cache
CANDLE_WARMUP_BARS=220
CHART_WINDOW_BARS=96

MODEL_NAME=gemini-2.5-flash
MODEL_ID=vertex_ai/gemini-2.5-flash
VERTEX_LOCATION=global
VERTEX_PROJECT=
GOOGLE_CLOUD_PROJECT=
# Prefer VM service account over key files in cloud.
GOOGLE_APPLICATION_CREDENTIALS=
LITELLM_TIMEOUT_SECONDS=120
LITELLM_DEBUG=false
LITELLM_LOG=ERROR
LITELLM_LOG_PROMPT=false
LITELLM_LOG_RESPONSE=false
LITELLM_RESPONSE_PREVIEW_CHARS=600
LITELLM_DROP_PARAMS=true
LITELLM_SUPPRESS_PYDANTIC_WARNINGS=true

IMAGE_PROVIDER=gcs
GCS_BUCKET_NAME=alphard-charts-CHANGE_ME
GCS_PUBLIC_READ=false

STRATEGY_NAME=levels_strategy
EXECUTION_MODE=pending_limit
BASE_VOLUME=0.01
MAX_VOLUME=0.05
MIN_CONFIDENCE=0.55
MAX_ALLOCATION=0.50
MAX_ACTIVE_POSITIONS=1
ENTRY_PULLBACK_POINTS=30
MIN_STOP_DISTANCE_POINTS=20
CANCEL_STALE_PENDING_ORDERS=true
MT5_MAGIC=424242
MT5_TYPE_FILLING=AUTO
MT5_DEVIATION=30
