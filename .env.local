# Pick this file with: ENV_FILE=.env.local python app.py --once
APP_NAME=alphard
APP_ENV=local
DRY_RUN=true
ADVISORY_ONLY=true
LOG_LEVEL=INFO

# Loop cadence. Use 15 or 30.
RUN_INTERVAL_MINUTES=5
CANDLE_CLOSE_DELAY_SECONDS=30

# MT5 proxy API
MT5_BASE_URL=http://127.0.0.1:8000
MT5_API_KEY=dev-api-key
MT5_TIMEOUT_SECONDS=30
TRADING_ENABLED=false

# Instruments and data
SYMBOLS=EURUSD,USDJPY
MT5_TIMEFRAME=M1
CANDLE_WARMUP_BARS=1800
DETAILED_ANALYSIS_BARS=180
GLOBAL_ANALYSIS_BARS=1560
CHART_WINDOW_BARS=180
CHART_CONTEXT_WINDOW_BARS=1560
GLOBAL_CHART_ASPECT=16:9
DETAILED_CHART_ASPECT=1:1
SQLITE_PATH=data/alphard.sqlite3
DATA_DIR=data
IMAGE_CACHE_DIR=img_cache

# LiteLLM / Gemini at GCP Vertex AI
MODEL_NAME=gemini-2.5-pro
MODEL_ID=vertex_ai/gemini-2.5-pro
VERTEX_LOCATION=global
VERTEX_PROJECT=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=./alphard-trader-sa-key.json
LITELLM_TIMEOUT_SECONDS=120
LITELLM_DEBUG=false
LITELLM_LOG=ERROR
LITELLM_LOG_PROMPT=false
LITELLM_LOG_RESPONSE=false
LITELLM_RESPONSE_PREVIEW_CHARS=600
LITELLM_DROP_PARAMS=true
LITELLM_SUPPRESS_PYDANTIC_WARNINGS=true

# Images: local embeds base64 into prompt; gcs uploads charts and sends gs:// or HTTPS link.
IMAGE_PROVIDER=local
GCS_BUCKET_NAME=
GCS_PUBLIC_READ=false

# Strategy and execution
STRATEGY_NAME=levels_strategy
ADVISORY_STRATEGY_NAME=advisory_two_scale_strategy
EXECUTION_MODE=pending_limit
BASE_VOLUME=0.01
MAX_VOLUME=0.05
MIN_CONFIDENCE=0.55
MAX_ALLOCATION=0.50
MAX_ACTIVE_POSITIONS=1
ENTRY_PULLBACK_POINTS=30
MIN_STOP_DISTANCE_POINTS=20
CANCEL_STALE_PENDING_ORDERS=true
MT5_MAGIC=424242
MT5_TYPE_FILLING=AUTO
MT5_DEVIATION=30
